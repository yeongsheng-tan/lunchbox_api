{
  "packages": [
    "beam28Packages.elixir_1_19@1.19.5",
    "postgresql_18@latest",
    "gigalixir@latest",
    "nodejs@25.9.0",
    "corepack@latest"
  ],
  "env": {
    "DEVBOX_COREPACK_ENABLED": "1"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox for lunchbox_api!' > /dev/null",
      "export BASIC_AUTH_USERNAME=specialUserName",
      "export BASIC_AUTH_PASSWORD=superSecretPassword",
      "cd assets && pnpm install --frozen-lockfile"
    ],
    "scripts": {
      "test": "BASIC_AUTH_USERNAME=specialUserName BASIC_AUTH_PASSWORD=superSecretPassword mix test",
      "dev":  "mix phx.server"
    }
  }
}
